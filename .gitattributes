# Normalize line endings to LF for Python files on checkout
# This prevents CRLF/LF mismatch between Windows development and Linux CI
*.py     text eol=lf
*.pyi    text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.sql    text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.jsx    text eol=lf
*.tsx    text eol=lf