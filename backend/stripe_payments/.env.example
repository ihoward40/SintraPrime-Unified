# Stripe Configuration
# Get these from: https://dashboard.stripe.com/developers/api-keys

# Test Keys (for development)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Live Keys (for production - DO NOT commit)
# STRIPE_SECRET_KEY=sk_live_your_secret_key_here
# STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product Price IDs
# Create these in your Stripe dashboard under Products
STRIPE_PRICE_STARTER=price_1234567890abc
STRIPE_PRICE_PRO=price_0987654321xyz
STRIPE_PRICE_ENTERPRISE=price_enterprise_123

# Airtable Configuration
AIRTABLE_BASE_ID=appYourBaseIdHere
AIRTABLE_API_TOKEN=patYourTokenHere

# Environment
ENVIRONMENT=test  # test or production

# URLs
DASHBOARD_URL=https://app.sintraprime.com
API_BASE_URL=http://localhost:8000

# Email Configuration
SENDGRID_API_KEY=SG.your_sendgrid_key_here
FROM_EMAIL=payments@sintraprime.com

# Logging
LOG_LEVEL=INFO
