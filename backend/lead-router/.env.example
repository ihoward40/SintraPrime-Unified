# Airtable Configuration
AIRTABLE_API_KEY=pat_your_api_key_here
AIRTABLE_BASE_ID=appYourBaseIdHere

# Email Configuration
EMAIL_PROVIDER=sendgrid  # or "ses"
SENDGRID_API_KEY=SG.your_sendgrid_key_here
AWS_SES_REGION=us-east-1
FROM_EMAIL=leads@sintraprime.ai

# Calendly Configuration
CALENDLY_URL=https://calendly.com/sintraprime/demo

# Tasklet Integration (optional)
TASKLET_API_ENABLED=false
TASKLET_API_KEY=your_tasklet_key_here
TASKLET_WORKSPACE_ID=your_workspace_id_here

# Slack Integration (optional)
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-your-slack-token

# Follow-up Schedule (days)
FOLLOWUP_FIRST_REMINDER_DAYS=3
FOLLOWUP_SECOND_REMINDER_DAYS=7

# Server Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=INFO

# Lead Routing Thresholds
LEGAL_SPECIALIST_THRESHOLD=70
FINANCIAL_SPECIALIST_THRESHOLD=70
COMBINED_SPECIALIST_THRESHOLD=50
GENERAL_INQUIRY_THRESHOLD=50
