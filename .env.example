# SintraPrime-Unified Environment Configuration
# =============================================
# Copy this file to .env and fill in your values:
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env
#
# The SETUP_WINDOWS.ps1 script auto-generates .env with secure random secrets.
# You only need to manually add API keys and integrations below.

# === REQUIRED — Database & Cache ===
POSTGRES_PASSWORD=change_me_strong_password_min_16_chars
REDIS_PASSWORD=change_me_redis_password

# === REQUIRED — Application Secrets ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_32_char_secret_key_here_xxxxxxxxxxxxxxxx
JWT_SECRET=change_me_jwt_secret_here_xxxxxxxxxxxxxxxxxxxxxxxx

# === AI API KEYS (optional but recommended) ===
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# === SLACK INTEGRATION (optional) ===
# Create app at https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# === DISCORD INTEGRATION (optional) ===
# Create bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=...
DISCORD_GUILD_ID=...

# === GITHUB INTEGRATION (optional) ===
# Create token at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=...

# === GHL/CRM INTEGRATION (optional) ===
GHL_API_KEY=...
GHL_LOCATION_ID=...

# === NOTION INTEGRATION (optional) ===
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=...

# === GRAFANA ===
GRAFANA_PASSWORD=admin

# === MINIO Object Storage ===
MINIO_PASSWORD=minioadmin123

# === TWIN LAYER ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TWIN_AUTH_TOKEN=change-me-in-production

# === PORTS (change if conflicts with existing services) ===
API_PORT=8080
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ELASTICSEARCH_PORT=9200

# === LOG LEVEL ===
LOG_LEVEL=INFO

# === FEATURES (enable/disable modules) ===
ENABLE_SUPERINTELLIGENCE=true
ENABLE_TWIN_TUI=true
ENABLE_AGENT_SWARMS=true
ENABLE_HIVE_MIND=true
ENABLE_VOICE=false
ENABLE_VLM=false

# === SECURITY HARDENING ===
# Comma-separated allowed origins — do NOT use * in production
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# Set to false in production to disable unsafe dynamic code execution
NOVA_ALLOW_DYNAMIC_EXEC=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
IDEMPOTENCY_TTL_SECONDS=86400
MAX_WEBHOOK_PAYLOAD_BYTES=1048576

# === IKEOS / TOOLGATEWAY ===
IKEOS_GATEWAY_URL=https://gateway.ikeos.internal
IKEOS_API_KEY=REPLACE_WITH_IKEOS_API_KEY
IKEOS_RISK_LEVEL_MAX=2

# === SSO/SAML Configuration ===
# Required for SAML/SSO authentication
SSO_JWT_SECRET_KEY=your-256-bit-secret-key-minimum-32-characters
SSO_ISSUER=https://your-sso-provider.example.com
SSO_AUDIENCE=https://your-app.example.com
SSO_JWT_ALGORITHM=HS256
SSO_JWT_EXPIRATION_SECONDS=3600
SSO_JWT_REFRESH_EXPIRATION_SECONDS=604800
SSO_SESSION_STORE_TYPE=redis
SSO_REQUIRE_HTTPS=true
SSO_SECURE_COOKIES=true
SSO_SAME_SITE_COOKIE=Strict
REDIS_URL=redis://localhost:6379/0
